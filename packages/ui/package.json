{
  "name": "@zooid/ui",
  "version": "0.0.18",
  "type": "module",
  "license": "MIT",
  "author": "Ori Ben",
  "repository": {
    "type": "git",
    "url": "https://github.com/zooid-ai/zooid",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src"
  ],
  "svelte": "./src/index.ts",
  "exports": {
    ".": {
      "svelte": "./src/index.ts"
    },
    "./components/*": {
      "svelte": "./src/components/*/index.ts"
    },
    "./lib/*": "./src/lib/*",
    "./styles/*": "./src/styles/*"
  },
  "dependencies": {
    "bits-ui": "^1.3.7",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.0",
    "tailwind-variants": "^1.0.0"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  }
}
