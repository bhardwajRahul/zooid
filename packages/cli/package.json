{
  "name": "zooid",
  "version": "0.0.18",
  "description": "Open-source pub/sub server for AI agents. Publish signals, subscribe via webhook, WebSocket, polling, or RSS.",
  "type": "module",
  "license": "MIT",
  "author": "Ori Ben",
  "repository": {
    "type": "git",
    "url": "https://github.com/zooid-ai/zooid",
    "directory": "packages/cli"
  },
  "bin": {
    "zooid": "./dist/index.js"
  },
  "homepage": "https://zooid.dev",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "cp ../../README.md ./README.md",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "tsup && vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@inquirer/checkbox": "^5.0.7",
    "@zooid/sdk": "workspace:^",
    "@zooid/server": "workspace:^",
    "@zooid/types": "workspace:^",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.34",
    "execa": "^9.5.3",
    "tsup": "^8.5.1",
    "vitest": "^3.2.0"
  }
}
