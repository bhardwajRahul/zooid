{
  "name": "@zooid/server",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "author": "Ori Ben",
  "repository": {
    "type": "git",
    "url": "https://github.com/zooid-ai/zooid",
    "directory": "packages/server"
  },
  "scripts": {
    "dev": "wrangler d1 execute zooid-db-zooid --local --file=src/db/schema.sql --persist-to .wrangler/state && wrangler d1 execute zooid-db-zooid --local --file=src/db/seed.sql --persist-to .wrangler/state && wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "wrangler.toml"
  ],
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@zooid/types": "workspace:^",
    "@zooid/web": "workspace:^",
    "chanfana": "^3.0.0",
    "fast-xml-parser": "^5.3.6",
    "hono": "^4.11.9",
    "ulidx": "^2.4.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.13",
    "@cloudflare/workers-types": "^4.20260217.0",
    "@vitest/coverage-istanbul": "^3.2.4",
    "wrangler": "^4.66.0"
  }
}
