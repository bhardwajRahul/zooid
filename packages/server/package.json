{
  "name": "@zooid/server",
  "version": "0.5.1",
  "type": "module",
  "license": "MIT",
  "author": "Ori Ben",
  "repository": {
    "type": "git",
    "url": "https://github.com/zooid-ai/zooid",
    "directory": "packages/server"
  },
  "scripts": {
    "dev": "rm -rf .wrangler/state && wrangler d1 execute zooid-db-zooid --local --file=src/db/schema.sql --persist-to .wrangler/state && wrangler d1 execute zooid-db-zooid --local --file=src/db/seed.sql --persist-to .wrangler/state && wrangler dev",
    "dev:seed": "curl -s -X POST http://localhost:8787/api/v1/_dev/seed | node -e \"process.stdin.on('data',d=>console.log(JSON.stringify(JSON.parse(d),null,2)))\"",
    "deploy": "wrangler deploy",
    "test": "vitest run"
  },
  "exports": {
    ".": "./src/index.ts",
    "./storage": "./src/storage/index.ts",
    "./routes": "./src/routes/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "wrangler.toml"
  ],
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@zooid/auth": "workspace:^",
    "@zooid/types": "workspace:^",
    "@zooid/web": "workspace:^",
    "chanfana": "^3.0.0",
    "fast-xml-parser": "^5.3.6",
    "hono": "^4.11.9",
    "ulidx": "^2.4.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.21",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@vitest/coverage-istanbul": "^3.2.4",
    "wrangler": "^4.66.0"
  }
}
